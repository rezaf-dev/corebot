APP_NAME=corebot
APP_KEY=
APP_URL=http://localhost
APP_DEBUG=true

# PostgreSQL with pgvector (required)
# CREATE EXTENSION IF NOT EXISTS vector;
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=corebot
DB_USERNAME=postgres
DB_PASSWORD=

# Queue worker required for knowledge indexing (use Horizon: php artisan horizon)
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Must exceed ProcessKnowledgeSourceJob timeout (300s)
REDIS_QUEUE_RETRY_AFTER=330

# Support form on the welcome page (use smtp/postmark/resend in production)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
SUPPORT_REQUEST_EMAIL=

# MaxMind GeoLite2 City database (.mmdb) for visitor country/city on widget chat
# GEOIP_DATABASE_PATH=/path/to/GeoLite2-City.mmdb

# Active bot public_key for /demo (from Bots in admin after migrate --seed)
DEMO_BOT_PUBLIC_KEY=

# Optional: Python 3 for DOCX knowledge indexing (defaults to python3 on PATH)
# DOCX_PYTHON=/path/to/corebot/.venv/bin/python3
